@page "/admin"
@using System.Reflection
@using Microsoft.AspNetCore.Components.WebAssembly.Services
@inject LazyAssemblyLoader Loader

<h1>Admin (lazy-loaded)</h1>

@if (loaded)
{
    <p>Admin module ready.</p>
}
else
{
    <button class="btn btn-primary" @onclick="LoadAdminAsync" disabled="@loading">
        @(loading ? "Loading..." : "Load Admin")
    </button>
}

@code {
    bool loading;
    bool loaded;

    async Task LoadAdminAsync()
    {
        loading = true;
        IEnumerable<Assembly> asms = await Loader.LoadAssembliesAsync(new[] { "AdminModule.dll" });
        // Once loaded, route templates inside the assembly are discoverable.
        loaded = true;
        loading = false;
    }
}
