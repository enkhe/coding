@page "/counter"
@rendermode InteractiveServer
@inject ILogger<Counter> Log

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>
<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>
<button class="btn btn-secondary" @onclick="Reset" disabled="@(currentCount == 0)">Reset</button>

@code {
    private int currentCount;

    private void IncrementCount()
    {
        currentCount++;
        Log.LogInformation("Counter incremented to {Count}", currentCount);
    }

    private void Reset() => currentCount = 0;
}
