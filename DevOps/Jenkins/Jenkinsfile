pipeline {
  agent {
    docker { image 'mcr.microsoft.com/dotnet/sdk:10.0' }
  }

  options {
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  environment {
    DOTNET_NOLOGO = 'true'
    DOTNET_CLI_TELEMETRY_OPTOUT = 'true'
  }

  stages {
    stage('Restore') {
      steps { sh 'dotnet restore --locked-mode' }
    }
    stage('Build') {
      steps { sh 'dotnet build --no-restore -c Release' }
    }
    stage('Test') {
      steps {
        sh '''
          dotnet test --no-build -c Release \
            --logger "trx;LogFileName=test.trx" \
            --collect:"XPlat Code Coverage"
        '''
      }
      post {
        always {
          junit '**/*.trx'
          archiveArtifacts artifacts: '**/coverage.cobertura.xml', allowEmptyArchive: true
        }
      }
    }
    stage('Container') {
      when { branch 'main' }
      agent any
      steps {
        withCredentials([usernamePassword(credentialsId: 'ghcr', usernameVariable: 'U', passwordVariable: 'P')]) {
          sh '''
            echo "$P" | docker login ghcr.io -u "$U" --password-stdin
            docker buildx build --push \
              --tag ghcr.io/contoso/orders-api:${GIT_COMMIT} \
              --platform linux/amd64,linux/arm64 .
          '''
        }
      }
    }
  }

  post {
    failure { mail to: 'platform@contoso.com', subject: "FAILED: ${env.JOB_NAME}", body: "${env.BUILD_URL}" }
    success { echo "OK: ${env.BUILD_URL}" }
  }
}
