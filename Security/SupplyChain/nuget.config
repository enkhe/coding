<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="contoso-internal" value="https://contoso.pkgs.visualstudio.com/_packaging/internal/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- Defends against dependency confusion: Contoso.* MUST come from internal feed. -->
  <packageSourceMapping>
    <packageSource key="contoso-internal">
      <package pattern="Contoso.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <!-- Trusted signers (Microsoft + your internal CA). -->
  <trustedSigners>
    <repository name="nuget.org" serviceIndex="https://api.nuget.org/v3/index.json">
      <certificate fingerprint="0E5F38F57DC1BCC806D8494F4F90FBCEDD988B46760709CBEEC6F4219AA6157D"
                   hashAlgorithm="SHA256" allowUntrustedRoot="false" />
      <owners>microsoft;dotnet;dotnetfoundation</owners>
    </repository>
  </trustedSigners>
</configuration>
