{
  "Jwt": {
    "Authority": "https://login.microsoftonline.com/<tenant-id>/v2.0",
    "Audience": "api://orders-gateway"
  },
  "ReverseProxy": {
    "Routes": {
      "orders": {
        "ClusterId": "orders",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "default",
        "Transforms": [
          { "PathRemovePrefix": "/api" },
          { "RequestHeader": "X-Forwarded-For", "Append": "{RemoteIpAddress}" },
          { "RequestHeader": "X-Forwarded-Host", "Set": "{Host}" }
        ]
      },
      "legacy": {
        "ClusterId": "legacy",
        "Match": { "Path": "/{**catch-all}" },
        "Order": 100
      }
    },
    "Clusters": {
      "orders": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "https://orders.internal/" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/ready"
          }
        }
      },
      "legacy": {
        "Destinations": {
          "d1": { "Address": "https://legacy-monolith.internal/" }
        }
      }
    }
  }
}
